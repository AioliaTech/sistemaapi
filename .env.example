# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Admin panel credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-use-a-strong-password

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# Base URL shown in the dashboard (no trailing slash)
BASE_URL=http://localhost:3000

# Bright Data Web Unlocker — para acessar fontes que bloqueiam IPs de datacenter (ex: revendamais.com.br)
# API Key disponível em: https://brightdata.com/cp/setting
# Zone: nome da zona Web Unlocker criada no painel (ex: web_unlocker1)
# Deixe em branco para não usar o Web Unlocker
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=web_unlocker1

# Photo Cache — Volume Hetzner montado localmente
# Requer: volume montado em PHOTO_DIR e PHOTO_CACHE_ENABLED=true
# Docs: montar o volume no path PHOTO_DIR e adicionar bind mount na stack Portainer
PHOTO_CACHE_ENABLED=false
PHOTO_DIR=/mnt/api-estoque-carmillion
SHORT_DOMAIN=https://api.revendai.com/f
PHOTO_DB_PATH=/app/data/photo_cache.db
